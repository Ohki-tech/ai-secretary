# LINE
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# Claude API
ANTHROPIC_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# Render.comデプロイ用（tokens/google_token.json の中身をそのまま貼る）
RENDER_GOOGLE_TOKEN_JSON=

# アプリ設定
PORT=3000
NODE_ENV=development

# ========== 請求書リマインダー ==========
# node tools/get_group_id.js を実行して取得してください
LINE_GROUP_ID_REMINDER=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# リマインドメッセージ内の送信者名（例: 山田太郎）
REMINDER_SENDER_NAME=あなたの名前
# 書類の送付先連絡先（メールアドレスやLINE等）
REMINDER_CONTACT_INFO=your-email@example.com
# リマインド宛先の呼び方（例: 皆さま、関係者の皆様）
REMINDER_TARGET_GROUP=皆さま
# 送付を依頼する書類の名称（例: 請求書、報告書）
REMINDER_DOCUMENT_NAME=書類
# 締め切りの説明（例: 各月第三金曜日）
REMINDER_DEADLINE_DESC=各月第三金曜日
